<UserControl x:Class="SmartWateringSystem.Views.PlantPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Converters="clr-namespace:SmartWateringSystem.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SmartWateringSystem.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SmartWateringSystem.ViewModels"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="300"
             d:DesignWidth="525"
             mc:Ignorable="d"
             xmlns:design="clr-namespace:SmartWateringSystem.Designer"
             d:DataContext="{d:DesignInstance design:DesignPlantPageViewModel, IsDesignTimeCreatable=True}">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
            <TextBlock HorizontalAlignment="Left"
                       TextBlock.FontSize="18"
                       Height="26"
                       Text="{Binding PlantName}"
                       TextWrapping="Wrap" 
                       FontWeight="Bold" />
            <Button Margin="10,0,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Command="{Binding EditNameCommand, Mode=OneWay}"
                    Content="Edit" />
        </StackPanel>

        <TextBlock Grid.Column="0" 
                   Grid.Row="1" 
                   VerticalAlignment="Center"
                   Text="Current Humidity:"/>
        <TextBlock Grid.Column="1" 
                   Grid.Row="1" 
                   VerticalAlignment="Center"
                   Text="{Binding CurrentHumidity}"/>

        <TextBlock Grid.Column="0" 
                   Grid.Row="2" 
                   TextAlignment="Left"
                   VerticalAlignment="Center"
                   Text="Humidity threshold to automatically start pump:"/>
        <TextBox x:Name="MinHumidityThresholdText" 
                 Grid.Column="1" 
                 Grid.Row="2" 
                 TextAlignment="Left"
                 VerticalContentAlignment="Center"
                 Text="{Binding MinHumidityThreshold, 
                                Mode=TwoWay, 
                                UpdateSourceTrigger=PropertyChanged,
                                ValidatesOnExceptions=True,
                                FallbackValue=0}"/>

        <TextBlock Grid.Column="0" 
                   Grid.Row="3" 
                   VerticalAlignment="Center"
                   Text="Start pump automatically:"/>
        <CheckBox Grid.Column="1" 
                 Grid.Row="3" 
                 Height="15"
                 Width="15"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Left"
                 IsChecked="{Binding AutomaticSystemEnabled , Mode=TwoWay}"/>

        <TextBlock Grid.Column="0" 
                   Grid.Row="4" 
                   VerticalAlignment="Center"
                   Text="Pump status:"/>
        <TextBlock Grid.Column="1" 
                   Grid.Row="4" 
                   VerticalAlignment="Center"
                   Text="{Binding PumpCommandState}"/>

        <TextBlock Grid.Column="0" 
                   Grid.Row="5" 
                   VerticalAlignment="Center"
                   Text="Time since pump started:"/>
        <TextBlock Grid.Column="1" 
                   Grid.Row="5" 
                   VerticalAlignment="Center"
                   Text="{Binding PumpActiveTimer, StringFormat={}{0:mm\\:ss}}"/>

        <StackPanel Margin="0,10,0,0" Orientation="Horizontal" Grid.ColumnSpan="2" Grid.Row="6" HorizontalAlignment="Center">
            <Button Width="110"
                    Height="31"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Command="{Binding StartPumpCommand, Mode=OneWay}"
                    Content="Start pump" />
            <Button Width="110"
                    Margin="50,0,0,0"
                    Height="31"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Command="{Binding StopPumpCommand, Mode=OneWay}"
                    Content="Stop pump" />
        </StackPanel>

    </Grid>
</UserControl>
