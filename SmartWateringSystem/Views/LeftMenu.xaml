<UserControl x:Class="SmartWateringSystem.Views.LeftMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SmartWateringSystem.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"            
             d:DesignHeight="300"
             mc:Ignorable="d">

    <StackPanel Margin="10">

        <Button Width="78"
                Height="25"
                HorizontalAlignment="Left"
                Command="{Binding NavigateToSummaryPageCommand}"
                Content="Summary" />

        <Separator Margin="5" />

        <ItemsControl ItemsSource="{Binding Plants}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Width="78"
                        Height="25"
                        Margin="0,5"
                        Command="{Binding DataContext.NavigateToPlantPageCommand,
                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                        Content="{Binding PlantName}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        
    </StackPanel>
</UserControl>
